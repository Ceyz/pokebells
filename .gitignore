memory.md
pokebells_roadmap*.html

# Local research / prototype work not meant for the public companion repo
game/*
poc/
download.py
patch-rom.py
poc-memory.html
test-nintondo.html

# One-shot dev tools (sprite pack generator, future extraction scripts).
# Private by default; allowlist specific files here if/when ready to publish.
# NOTE: `tools/*` (not `tools/`) so the `!tools/foo` whitelists below work —
# Git refuses to re-include a file whose parent directory is excluded.
tools/*
!tools/package-indexer-for-inscription.mjs
!tools/apply-d1-schema.mjs
!tools/bulk-inscribe.mjs
!tools/bulk-inscribe.test.mjs
!tools/bulk-inscribe-collection.test.mjs
!tools/phase-b-live-probe.mjs
!tools/probe-clone-injection.mjs
# Clone-injection probe log — origin-safety follow-up evidence.
!tools/probe-clone-injection.log
# Live probe log — kept in repo as evidence of the Phase B + C PASS.
!tools/phase-b-live-probe.log
!tools/gen-bells-wallet.mjs
!tools/BULK-INSCRIBE.md
!tools/build-inscription-plan.mjs
!tools/probe-sat-spend.mjs
!tools/PROBE-SAT-SPEND.md
!tools/TESTNET-LIVE-P0.md
!tools/probe-sat-spend.log
tools/bulk-inscribe-state.*.json
!tools/pokebells-inscriber/
