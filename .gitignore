# Game ROM and IP-derived assets — NEVER commit
pokemon_red.gb
*.gb
*.gbc
*.sav
shin_patch.zip
*.bps
*.ips

# ROM chunks generated for inscriptions (encoded ROM)
game/chunks/

# Reverse-engineering artifacts (Nintondo extension/viewer bundles)
game/tmp-*

# Local TLS dev certs (private keys!)
game/.https-cert/
*.pem
*.key

# Local Claude config
.claude/

